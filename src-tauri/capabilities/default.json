{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "C-Box default capability",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "powershell",
          "cmd": "powershell.exe",
          "args": ["-NoProfile", "-NonInteractive", "-Command", { "validator": ".+" }],
          "sidecar": false
        },
        {
          "name": "pwsh",
          "cmd": "pwsh",
          "args": ["-NoProfile", "-NonInteractive", "-Command", { "validator": ".+" }],
          "sidecar": false
        }
      ]
    }
  ]
}
